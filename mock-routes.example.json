{
  "getUsers": {
    "method": "GET",
    "path": "/api/users",
    "status": 200,
    "body": { "users": [{ "id": 1, "name": "Alice" }, { "id": 2, "name": "Bob" }] }
  },
  "getUserById": {
    "method": "GET",
    "path": "/api/users/:id",
    "status": 200,
    "body": { "id": 1, "name": "Alice", "email": "alice@example.com" }
  },
  "createUser": {
    "method": "POST",
    "path": "/api/users",
    "status": 201,
    "body": { "id": 3, "name": "New User" },
    "headers": { "X-Request-Id": "mock-001" }
  },
  "deleteUser": {
    "method": "DELETE",
    "path": "/api/users/:id",
    "status": 204,
    "body": null
  },
  "slowEndpoint": {
    "method": "GET",
    "path": "/api/reports",
    "status": 200,
    "body": { "report": "data" },
    "delay": 800
  }
}
